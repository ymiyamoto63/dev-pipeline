#!/usr/bin/env bash
# gh CLI extension entry point for dev-pipeline (GitHub Copilot version).
# Usage: gh dev-pipeline [target-dir]   (default target-dir: .)
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TARGET_DIR="${1:-.}"

if [ ! -d "$TARGET_DIR/.git" ]; then
  echo "error: $TARGET_DIR is not a git repository root (no .git found)" >&2
  exit 1
fi

mkdir -p "$TARGET_DIR/.github/agents" "$TARGET_DIR/.github/prompts"
cp "$SCRIPT_DIR/copilot/agents/"*.agent.md "$TARGET_DIR/.github/agents/"
cp "$SCRIPT_DIR/copilot/prompts/"*.prompt.md "$TARGET_DIR/.github/prompts/"

echo "Installed dev-pipeline (Copilot) into $TARGET_DIR/.github/agents and $TARGET_DIR/.github/prompts"
